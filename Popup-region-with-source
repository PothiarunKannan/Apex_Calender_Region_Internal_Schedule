create inline popup static region with the static ID of MEETING_POPUP

this region will be called when click of the event for registeration


<div class="meeting-popup-body">

  <div class="meeting-popup-domain" id="pop-domain"></div>
  <div class="meeting-popup-title"  id="pop-title"></div>

  <div class="meeting-popup-grid">
    <div class="meeting-popup-item">
      <span class="pop-label">👤 Presenter</span>
      <span class="pop-value" id="pop-presenter"></span>
    </div>
    <div class="meeting-popup-item">
      <span class="pop-label">🏢 Department</span>
      <span class="pop-value" id="pop-dept"></span>
    </div>
    <div class="meeting-popup-item">
      <span class="pop-label">📅 Date</span>
      <span class="pop-value" id="pop-date"></span>
    </div>
    <div class="meeting-popup-item">
      <span class="pop-label">🕐 Time</span>
      <span class="pop-value" id="pop-time"></span>
    </div>
    <div class="meeting-popup-item">
      <span class="pop-label">👥 Registered</span>
      <span class="pop-value" id="pop-count"></span>
    </div>
  </div>

  <div class="meeting-register-wrap">
    <button id="btn-register-toggle" class="meeting-reg-btn">
      Loading...
    </button>
    <span id="reg-feedback" class="reg-feedback"></span>
  </div>

</div>



