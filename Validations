On Click of submit button - Dynamic Action with two true actions

First True Action :- (PLSQL)
DECLARE
    Lv_count NUMBER;
BEGIN
    -- ✅ Clear error first
    :P23_ERROR_MSG := NULL;

    -- ✅ Check 1: Time slot already taken (highest priority)
    SELECT COUNT(*) INTO Lv_count
    FROM internal_meetings
    WHERE MEETING_DATE = :P23_MEETING_DATE
    AND   MEETING_TIME = :P23_MEETING_TIME;

    IF Lv_count > 0 THEN
        :P23_ERROR_MSG := 'Sorry, this time slot is already scheduled.';
        RETURN; -- ✅ Exit immediately, no need to check further
    END IF;

    -- ✅ Check 2: Same dept already has session on this date
    SELECT COUNT(*) INTO Lv_count
    FROM internal_meetings
    WHERE MEETING_DATE      = :P23_MEETING_DATE
    AND   PRESENTER_DEPT_NO = :P23_DEPTNO;

    IF Lv_count > 0 THEN -- ✅ Fixed: > 0 not > 1
        :P23_ERROR_MSG := 'The selected date is already booked for another session in your team.';
        RETURN; -- ✅ Exit immediately
    END IF;

    -- ✅ Check 3: Daily session limit reached
    SELECT COUNT(*) INTO Lv_count
    FROM internal_meetings
    WHERE MEETING_DATE = :P23_MEETING_DATE;

    IF Lv_count >= 3 THEN -- ✅ Fixed: >= 3 not > 3
        :P23_ERROR_MSG := 'Only 3 internal sessions are allowed per day. Please choose another date.';
        RETURN; -- ✅ Exit immediately
    END IF;

END;


